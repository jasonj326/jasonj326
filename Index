    if (!coopInput.trim()) return;
    
    setIsGenerating(true);
    setApiError('');
    setGeneratedQuest(null);

    const prompt = `You are a game master for Jason J. Lai's personal website. Jason is a 'Legal Builder' navigating Web3, AI, and regulatory gray zones. The user wants to collaborate. User's background/idea: "${coopInput}". Generate a short, fun RPG-style 'Co-op Quest' for them to tackle together. Please structure it with:
