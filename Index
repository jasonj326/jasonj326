          <div className="flex space-x-6">
            <button 
              onClick={() => setCurrentPage('home')}
              className={`font-mono font-bold tracking-tight transition-colors ${currentPage === 'home' ? 'text-indigo-600 dark:text-emerald-400' : 'hover:text-indigo-600 dark:hover:text-emerald-400'}`}
            >
              <Terminal className="w-5 h-5 inline-block mr-2 mb-1" />
              Jason_Lai
            </button>
            <button 
              onClick={() => setCurrentPage('3p')}
              className={`font-mono font-bold tracking-tight transition-colors ${currentPage === '3p' || currentPage === 'article' ? 'text-indigo-600 dark:text-emerald-400' : 'hover:text-indigo-600 dark:hover:text-emerald-400'}`}
            >
              3P_ZONE
            </button>
          </div>
          
          <div className="flex items-center space-x-4">
            <button 
              onClick={() => setIsDark(!isDark)}
              className="p-2 rounded-full hover:bg-slate-200 dark:hover:bg-slate-800 transition-colors"
              aria-label="Toggle dark mode"
            >
              {isDark ? <Sun className="w-5 h-5 text-amber-400" /> : <Moon className="w-5 h-5 text-slate-600" />}
            </button>
          </div>
        </div>
      </nav>

      {/* 路由邏輯 Router Logic */}
      {currentPage === 'home' && <HomePage setCurrentPage={setCurrentPage} />}
      {currentPage === '3p' && (
        <ThreePPage 
          setCurrentPage={setCurrentPage} 
          onArticleClick={(article) => {
            setSelectedArticle(article);
            setCurrentPage('article');
          }} 
        />
      )}
      {currentPage === 'article' && (
        <ArticlePage 
          article={selectedArticle} 
          onBack={() => setCurrentPage('3p')} 
        />
      )}

      {/* 頁尾 Global Footer */}
      <footer className="border-t border-slate-200 dark:border-slate-800 py-12 mt-12">
        <div className="max-w-4xl mx-auto px-6 flex flex-col sm:flex-row justify-between items-center text-sm font-mono text-slate-500">
          <p>© {new Date().getFullYear()} Jason Lai. Built with React & Tailwind.</p>
          <div className="flex space-x-6 mt-4 sm:mt-0">
            <a href="https://twitter.com/你的推特" target="_blank" rel="noopener noreferrer" className="hover:text-indigo-600 dark:hover:text-emerald-400">Twitter</a>
            <a href="https://github.com/jasonj326" target="_blank" rel="noopener noreferrer" className="hover:text-indigo-600 dark:hover:text-emerald-400">GitHub</a>
