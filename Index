        </div>
      </div>

      {/* 外部連結區塊 (YouTube & Podcast) */}
      <div className="grid sm:grid-cols-2 gap-6 mb-16">
        <a href="https://youtube.com/" target="_blank" rel="noopener noreferrer" className="flex items-center p-4 border-2 border-slate-900 dark:border-slate-300 rounded-xl bg-white dark:bg-slate-800 shadow-[4px_4px_0_0_rgba(15,23,42,1)] dark:shadow-[4px_4px_0_0_rgba(203,213,225,1)] hover:-translate-y-1 transition-transform cursor-pointer">
